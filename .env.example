# Environment variables for Kia of Portland – LeadBot

# ── Required ──────────────────────────────────────────────────────────────────
# Your OpenAI API key. Get one at https://platform.openai.com/api-keys
# Without this key the app runs in demo mode (canned responses only).
OPENAI_API_KEY=sk-...your-key-here...

# ── Optional ──────────────────────────────────────────────────────────────────
# Optional (default: 1024). Max tokens per AI response — lower to reduce costs.
MAX_TOKENS=1024
